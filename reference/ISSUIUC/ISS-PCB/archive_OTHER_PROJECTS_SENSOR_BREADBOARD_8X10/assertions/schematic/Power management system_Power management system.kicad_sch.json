{
  "file_pattern": "Power management system_Power management system.kicad_sch",
  "analyzer_type": "schematic",
  "generated_by": "generate_seed_assertions.py",
  "assertions": [
    {
      "id": "SEED-00000001",
      "description": "Component count ~12 (tolerance 10%)",
      "check": {
        "path": "statistics.total_components",
        "op": "range",
        "min": 10,
        "max": 14
      }
    },
    {
      "id": "SEED-00000002",
      "description": "Net count ~26 (tolerance 10%)",
      "check": {
        "path": "statistics.total_nets",
        "op": "range",
        "min": 23,
        "max": 29
      }
    },
    {
      "id": "SEED-00000003",
      "description": "BOM is non-empty",
      "check": {
        "path": "bom",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000004",
      "description": "Signal analysis section exists",
      "check": {
        "path": "signal_analysis",
        "op": "exists"
      }
    },
    {
      "id": "SEED-00000005",
      "description": "1 battery_chargers detected",
      "check": {
        "path": "signal_analysis.battery_chargers",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000006",
      "description": "All battery_chargers have charger_reference",
      "check": {
        "path": "signal_analysis.battery_chargers",
        "op": "not_contains_match",
        "field": "charger_reference",
        "pattern": "^$"
      }
    },
    {
      "id": "SEED-00000007",
      "description": "All battery_chargers charger_type values are valid",
      "check": {
        "path": "signal_analysis.battery_chargers",
        "op": "count_matches",
        "field": "charger_type",
        "pattern": "^(single_cell_linear|single_cell_switching|standalone_protection)$",
        "value": 1
      }
    },
    {
      "id": "SEED-00000008",
      "description": "1 design_observations detected",
      "check": {
        "path": "signal_analysis.design_observations",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000009",
      "description": "8 led_audit detected",
      "check": {
        "path": "signal_analysis.led_audit",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000010",
      "description": "All led_audit have ref",
      "check": {
        "path": "signal_analysis.led_audit",
        "op": "not_contains_match",
        "field": "ref",
        "pattern": "^$"
      }
    },
    {
      "id": "SEED-00000011",
      "description": "All led_audit type values are valid",
      "check": {
        "path": "signal_analysis.led_audit",
        "op": "count_matches",
        "field": "type",
        "pattern": "^(indicator_led)$",
        "value": 8
      }
    },
    {
      "id": "SEED-00000012",
      "description": "All led_audit drive_method values are valid",
      "check": {
        "path": "signal_analysis.led_audit",
        "op": "count_matches",
        "field": "drive_method",
        "pattern": "^(resistor_limited|direct_drive|ic_direct)$",
        "value": 8
      }
    },
    {
      "id": "SEED-00000013",
      "description": "Has 8 led(s)",
      "check": {
        "path": "statistics.component_types.led",
        "op": "min_count",
        "value": 6
      }
    }
  ]
