{
  "file_pattern": "AUDIO_OUT.sch",
  "analyzer_type": "schematic",
  "generated_by": "seed.py",
  "evidence_source": "auto_seeded",
  "assertions": [
    {
      "id": "SEED-00000001",
      "description": "Component count ~20 (tolerance 10%)",
      "check": {
        "path": "statistics.total_components",
        "op": "range",
        "min": 18,
        "max": 22
      }
    },
    {
      "id": "SEED-00000002",
      "description": "Net count ~24 (tolerance 10%)",
      "check": {
        "path": "statistics.total_nets",
        "op": "range",
        "min": 21,
        "max": 27
      }
    },
    {
      "id": "SEED-00000003",
      "description": "BOM is non-empty",
      "check": {
        "path": "bom",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000004",
      "description": "Findings section exists",
      "check": {
        "path": "findings",
        "op": "exists"
      }
    },
    {
      "id": "SEED-00000005",
      "description": "1 audit_rail_sources detected",
      "check": {
        "path": "findings",
        "detector_filter": "audit_rail_sources",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000006",
      "description": "1 detect_audio_circuits detected",
      "check": {
        "path": "findings",
        "detector_filter": "detect_audio_circuits",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000007",
      "description": "All detect_audio_circuits have ref",
      "check": {
        "path": "findings",
