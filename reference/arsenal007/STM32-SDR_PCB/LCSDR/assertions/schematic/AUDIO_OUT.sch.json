    {
      "id": "SEED-00000008",
      "description": "All detect_audio_circuits type values are valid",
      "check": {
        "path": "findings",
        "detector_filter": "detect_audio_circuits",
        "op": "count_matches",
        "field": "type",
        "pattern": "^(audio_amplifier|audio_codec)$",
        "value": 1
      }
    },
    {
      "id": "SEED-00000009",
      "description": "2 detect_lc_filters detected",
      "check": {
        "path": "findings",
        "detector_filter": "detect_lc_filters",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000010",
      "description": "All detect_lc_filters have non-zero resonant_hz",
      "check": {
        "path": "findings",
        "detector_filter": "detect_lc_filters",
        "op": "not_contains_match",
        "field": "resonant_hz",
        "pattern": "^(0(\\.0+)?|None|)$"
      }
    },
    {
      "id": "SEED-00000011",
      "description": "2 detect_rc_filters detected",
      "check": {
        "path": "findings",
        "detector_filter": "detect_rc_filters",
        "op": "min_count",
        "value": 1
      }
    },
    {
