      "check": {
        "path": "findings",
        "detector_filter": "detect_rc_filters",
        "op": "not_contains_match",
        "field": "cutoff_hz",
        "pattern": "^(0(\\.0+)?|None|)$"
      }
    },
    {
      "id": "SEED-00000013",
      "description": "Has 11 capacitor(s)",
      "check": {
        "path": "statistics.component_types.capacitor",
