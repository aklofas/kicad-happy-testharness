      "check": {
        "path": "signal_analysis.motor_drivers",
        "op": "count_matches",
        "field": "driver_type",
        "pattern": "^(stepper|dc_brushed_h_bridge)$",
        "value": 1
      }
    },
    {
      "id": "SEED-00000009",
      "description": "1 power_regulators detected",
      "check": {
        "path": "signal_analysis.power_regulators",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000010",
      "description": "All power_regulators have ref present",
      "check": {
        "path": "signal_analysis.power_regulators",
        "op": "not_contains_match",
        "field": "ref",
        "pattern": "^(None|\\?|)$"
      }
    },
    {
      "id": "SEED-00000011",
      "description": "1 rc_filters detected",
      "check": {
        "path": "signal_analysis.rc_filters",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000012",
      "description": "All rc_filters have non-zero cutoff_hz",
      "check": {
        "path": "signal_analysis.rc_filters",
        "op": "not_contains_match",
        "field": "cutoff_hz",
        "pattern": "^(0(\\.0+)?|None|)$"
      }
    },
    {
      "id": "SEED-00000013",
      "description": "2 voltage_dividers detected",
      "check": {
        "path": "signal_analysis.voltage_dividers",
