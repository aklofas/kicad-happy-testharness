{
  "file_pattern": "canton.sch",
  "analyzer_type": "schematic",
  "generated_by": "generate_seed_assertions.py",
  "assertions": [
    {
      "id": "SEED-00000001",
      "description": "Component count ~25 (tolerance 10%)",
      "check": {
        "path": "statistics.total_components",
        "op": "range",
        "min": 22,
        "max": 28
      }
    },
    {
      "id": "SEED-00000002",
      "description": "Net count ~20 (tolerance 10%)",
      "check": {
        "path": "statistics.total_nets",
        "op": "range",
        "min": 18,
        "max": 22
      }
    },
    {
      "id": "SEED-00000003",
      "description": "BOM is non-empty",
      "check": {
        "path": "bom",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000004",
      "description": "Signal analysis section exists",
      "check": {
        "path": "signal_analysis",
        "op": "exists"
      }
    },
    {
      "id": "SEED-00000005",
      "description": "1 design_observations detected",
      "check": {
        "path": "signal_analysis.design_observations",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000006",
      "description": "1 motor_drivers detected",
      "check": {
        "path": "signal_analysis.motor_drivers",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000007",
      "description": "All motor_drivers have driver_reference",
      "check": {
        "path": "signal_analysis.motor_drivers",
        "op": "not_contains_match",
