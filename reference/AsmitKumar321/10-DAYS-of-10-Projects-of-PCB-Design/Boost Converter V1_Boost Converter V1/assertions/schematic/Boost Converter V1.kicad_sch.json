{
  "file_pattern": "Boost Converter V1.kicad_sch",
  "analyzer_type": "schematic",
  "generated_by": "generate_seed_assertions.py",
  "assertions": [
    {
      "id": "SEED-00000001",
      "description": "Component count ~13 (tolerance 10%)",
      "check": {
        "path": "statistics.total_components",
        "op": "range",
        "min": 11,
        "max": 15
      }
    },
    {
      "id": "SEED-00000002",
      "description": "Net count ~6 (tolerance 10%)",
      "check": {
        "path": "statistics.total_nets",
        "op": "range",
        "min": 5,
        "max": 7
      }
    },
    {
      "id": "SEED-00000003",
      "description": "BOM is non-empty",
      "check": {
        "path": "bom",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000004",
      "description": "Signal analysis section exists",
      "check": {
        "path": "signal_analysis",
        "op": "exists"
      }
    },
    {
      "id": "SEED-00000005",
      "description": "2 esd_coverage_audit detected",
      "check": {
        "path": "signal_analysis.esd_coverage_audit",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000006",
      "description": "All esd_coverage_audit have connector_ref",
      "check": {
        "path": "signal_analysis.esd_coverage_audit",
        "op": "not_contains_match",
        "field": "connector_ref",
        "pattern": "^$"
      }
    },
    {
      "id": "SEED-00000007",
      "description": "All esd_coverage_audit coverage values are valid",
      "check": {
        "path": "signal_analysis.esd_coverage_audit",
        "op": "count_matches",
        "field": "coverage",
        "pattern": "^(full|partial|none)$",
        "value": 2
      }
    },
    {
      "id": "SEED-00000008",
      "description": "All esd_coverage_audit risk_level values are valid",
      "check": {
        "path": "signal_analysis.esd_coverage_audit",
        "op": "count_matches",
        "field": "risk_level",
        "pattern": "^(high_risk|medium_risk|low_risk)$",
        "value": 2
      }
    },
    {
      "id": "SEED-00000009",
      "description": "1 feedback_networks detected",
      "check": {
        "path": "signal_analysis.feedback_networks",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000010",
      "description": "All feedback_networks have r_top ref present",
      "check": {
        "path": "signal_analysis.feedback_networks",
        "op": "not_contains_match",
        "field": "r_top.ref",
        "pattern": "^(None|)$"
      }
    },
    {
      "id": "SEED-00000011",
      "description": "1 lc_filters detected",
      "check": {
        "path": "signal_analysis.lc_filters",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000012",
      "description": "All lc_filters have non-zero resonant_hz",
      "check": {
        "path": "signal_analysis.lc_filters",
        "op": "not_contains_match",
        "field": "resonant_hz",
        "pattern": "^(0(\\.0+)?|None|)$"
      }
    },
    {
      "id": "SEED-00000013",
      "description": "1 protection_devices detected",
      "check": {
        "path": "signal_analysis.protection_devices",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000014",
      "description": "1 voltage_dividers detected",
      "check": {
        "path": "signal_analysis.voltage_dividers",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000015",
      "description": "All voltage_dividers have non-zero ratio",
      "check": {
        "path": "signal_analysis.voltage_dividers",
        "op": "not_contains_match",
        "field": "ratio",
        "pattern": "^(0(\\.0+)?|None|)$"
      }
    }
