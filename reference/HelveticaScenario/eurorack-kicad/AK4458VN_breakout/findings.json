{
  "findings": [
    {
      "analyzer_type": "schematic",
      "source_file": "AK4458VN_breakout_AK4458VN_breakout.kicad_sch.json",
      "status": "promoted",
      "summary": "AK4458VN 8-ch DAC breakout (85 components). False parallel cap in RC filter inflates capacitance 10x. I2C config pins falsely detected as bus lines. NE5532 difference amplifiers classified as compensator. I2S/TDM audio interface not detected (no detector exists).",
      "correct": [
        {
          "description": "AK4458VN correctly classified as IC",
          "analyzer_section": "components",
          "check": {
            "path": "components",
            "op": "min_count",
            "value": 1
          }
        }
      ],
      "incorrect": [
        {
          "description": "RC filter R32(150ohm)+C14(120pF) falsely groups C11(1nF) as parallel \u2014 C11 shares only the input node, not the output node. Reported fc=947kHz vs correct 8.84MHz",
          "analyzer_section": "signal_analysis.rc_filters",
          "check": {
            "path": "signal_analysis.rc_filters",
            "op": "not_contains_match",
            "field": "resistor.ref",
            "pattern": "^R32$"
          },
          "detector": "rc_filters",
          "subject_refs": [
            "C11",
            "C14",
            "R32"
          ],
          "expected_relation": "not_in_detector",
          "confidence": 0.9
        },
        {
          "description": "NE5532 differential-to-single-ended output stages (U4-U7) classified as 'compensator' instead of difference amplifier",
          "analyzer_section": "signal_analysis.opamp_circuits",
          "check": {
            "path": "signal_analysis.opamp_circuits",
            "op": "not_contains_match",
            "field": "reference",
            "pattern": "^U4$"
          },
          "detector": "opamp_circuits",
          "subject_refs": [
            "U4",
            "U5",
            "U6",
            "U7"
          ],
          "expected_relation": "not_in_detector",
          "confidence": 0.9
        }
      ],
      "missed": [
        {
          "description": "I2S/TDM serial audio interface not detected \u2014 all 4 AK4458VN data bus signals present (MCLK, BICK, LRCK, SDTI1-4) but no I2S detector exists",
          "analyzer_section": "signal_analysis.bus_interfaces",
          "check": {
            "path": "signal_analysis.bus_interfaces",
            "op": "min_count",
            "value": 1
          },
          "detector": "bus_interfaces",
          "subject_refs": [],
          "expected_relation": "in_detector",
          "confidence": 0.7
        }
      ],
      "suggestions": [
        "Parallel-cap detection must verify both caps share the same two terminal nodes",
        "I2C bus detection should check for actual SDA/SCL bus topology, not just pin name substrings",
        "Add I2S/TDM audio serial interface detector"
      ],
