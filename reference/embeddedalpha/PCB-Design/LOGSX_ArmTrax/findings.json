          "check": {
            "path": "statistics",
            "op": "min_count",
            "value": 1
          }
        },
        {
          "description": "Crystal circuits Y1, Y2, Y3 with load caps correctly detected",
          "analyzer_section": "detect_crystal_circuits",
          "check": {
            "path": "findings",
            "op": "contains_match",
            "field": "reference",
            "pattern": "^Y1$",
            "detector_filter": "detect_crystal_circuits"
          },
          "detector": "crystal_circuits",
          "subject_refs": [
            "Y1",
            "Y2",
            "Y3"
          ],
          "expected_relation": "in_detector",
          "confidence": 0.9
        },
        {
