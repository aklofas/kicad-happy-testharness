          },
          "detector": "design_observations",
          "subject_refs": [
            "R2",
            "R3"
          ],
          "expected_relation": "count_equals",
          "confidence": 0.6,
          "expected_value": 3
        },
        {
          "description": "LC filters in radio section correctly identified",
