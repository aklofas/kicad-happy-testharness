        "min": 12,
        "max": 16
      }
    },
    {
      "id": "SEED-00000002",
      "description": "Net count ~10 (tolerance 10%)",
      "check": {
        "path": "statistics.total_nets",
        "op": "range",
        "min": 9,
        "max": 11
      }
    },
    {
      "id": "SEED-00000003",
      "description": "BOM is non-empty",
      "check": {
        "path": "bom",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000004",
      "description": "Signal analysis section exists",
      "check": {
        "path": "signal_analysis",
        "op": "exists"
      }
    },
    {
      "id": "SEED-00000005",
      "description": "2 decoupling_analysis detected",
      "check": {
        "path": "signal_analysis.decoupling_analysis",
        "op": "min_count",
        "value": 1
      }
