{
  "file_pattern": "power.sch",
  "analyzer_type": "schematic",
  "generated_by": "generate_seed_assertions.py",
  "assertions": [
    {
      "id": "SEED-00000001",
      "description": "Component count ~14 (tolerance 10%)",
      "check": {
