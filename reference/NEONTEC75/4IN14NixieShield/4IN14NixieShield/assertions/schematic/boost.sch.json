{
  "file_pattern": "boost.sch",
  "analyzer_type": "schematic",
  "generated_by": "generate_seed_assertions.py",
  "assertions": [
    {
      "id": "SEED-00000001",
      "description": "Component count ~10 (tolerance 10%)",
      "check": {
        "path": "statistics.total_components",
        "op": "range",
        "min": 9,
        "max": 11
      }
    },
    {
      "id": "SEED-00000002",
      "description": "Net count ~9 (tolerance 10%)",
      "check": {
        "path": "statistics.total_nets",
        "op": "range",
        "min": 8,
        "max": 10
      }
    },
    {
      "id": "SEED-00000003",
      "description": "BOM is non-empty",
      "check": {
        "path": "bom",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000004",
      "description": "Signal analysis section exists",
      "check": {
        "path": "signal_analysis",
        "op": "exists"
      }
    },
    {
      "id": "SEED-00000005",
      "description": "1 transistor_circuits detected",
      "check": {
        "path": "signal_analysis.transistor_circuits",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000006",
      "description": "All transistor_circuits have reference present",
      "check": {
        "path": "signal_analysis.transistor_circuits",
        "op": "not_contains_match",
        "field": "reference",
        "pattern": "^(None|\\?|)$"
      }
    },
    {
      "id": "SEED-00000007",
      "description": "1 voltage_dividers detected",
      "check": {
        "path": "signal_analysis.voltage_dividers",
        "op": "min_count",
        "value": 1
      }
    },
    {
      "id": "SEED-00000008",
      "description": "All voltage_dividers have non-zero ratio",
      "check": {
        "path": "signal_analysis.voltage_dividers",
        "op": "not_contains_match",
        "field": "ratio",
        "pattern": "^(0(\\.0+)?|None|)$"
      }
    }
  ]
}
